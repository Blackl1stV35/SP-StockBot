# ==================== LINE MESSAGING API ====================
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_SUPER_ADMIN_ID=U1234567890abcdef1234567890abcdef

# ==================== PIN SECURITY ====================
SUPER_ADMIN_PIN=7482

# ==================== GROQ CLOUD API ====================
GROQ_API_KEY=gq_your_groq_api_key_here

# ==================== GOOGLE DRIVE INTEGRATION ====================
# Either set GOOGLE_SERVICE_ACCOUNT_JSON to full JSON string (for production)
# Or set GOOGLE_SERVICE_ACCOUNT_PATH to path to service account JSON file
GOOGLE_SERVICE_ACCOUNT_PATH=./service_account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ==================== APPLICATION SETTINGS ====================
APP_ENV=development
APP_DEBUG=false
APP_PORT=8000
APP_WORKERS=1

# ==================== DATABASE ====================
DATABASE_PATH=./data/stockbot.db

# ==================== GOOGLE DRIVE FOLDER ====================
# Share the drive folder with bot's service account email first
# Then set the folder ID here
GOOGLE_DRIVE_FOLDER_ID=1234567890abcdef

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_DIR=./logs

# ==================== ANOMALY DETECTION ====================
ANOMALY_THRESHOLD_MULTIPLIER=3.0
ANOMALY_LOOKBACK_MONTHS=3

# ==================== BACKGROUND TASKS ====================
ENABLE_DAILY_SUMMARY=true
DAILY_SUMMARY_HOUR=17
WEEKLY_SUMMARY_DAY=0
WEEKLY_SUMMARY_HOUR=17
